# Cloudflare Pages redirects
# Note: Specific rules must come BEFORE splat/wildcard rules for performance

# Redirect favicon.ico to Cloudinary-hosted PNG for browser compatibility
/favicon.ico https://res.cloudinary.com/dn3j8sqcc/image/upload/c_thumb,g_face,w_32,h_32,z_1.0/f_png/otogi/cards_hd/100014_hd.png 301

# Exact match redirects (must be before splats)
/updates /en/updates 301
/updates/ /en/updates/ 301

# Splat/wildcard rules (must be LAST for performance)
# Redirect all non-English locales to English equivalent, preserving intended locale as ?lang=
/ja/* /en/:splat?lang=ja 301
/ko/* /en/:splat?lang=ko 301
/es/* /en/:splat?lang=es 301
/zh-cn/* /en/:splat?lang=zh-cn 301
/zh-tw/* /en/:splat?lang=zh-tw 301

# Backward compatibility: redirect old English URLs to /en/ prefix
/cards/* /en/cards/:splat 301
/blog/* /en/blog/:splat 301

# Cross-locale redirects for language switching (old URLs with wrong locale suffix)
# These handle cases where language switcher may have generated wrong URLs
/en/blog/*-ja /en/blog/:splat 301
/en/blog/*-ko /en/blog/:splat 301
/en/blog/*-es /en/blog/:splat 301
/en/blog/*-zh-cn /en/blog/:splat 301
/en/blog/*-zh-tw /en/blog/:splat 301
