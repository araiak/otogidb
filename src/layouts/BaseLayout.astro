    52|    52|    52|    52|    let hash = 0;
    53|    53|    53|    53|    // Use a larger sample of the file for speed while still being reliable
    54|    54|    54|    54|    const sample = content.slice(0, 50000) + content.slice(-50000);
    55|    55|    55|    55|    for (let i = 0; i < sample.length; i++) {
    56|    56|    56|    56|      const char = sample.charCodeAt(i);
    57|    57|    57|    57|      hash = ((hash << 5) - hash) + char;
    58|    58|    58|    58|      hash = hash & hash;
    59|    59|    59|    59|    }
    60|    60|    60|    60|    return Math.abs(hash).toString(36);
    61|    61|    61|    61|  } catch {
    62|    62|    62|    62|    return Date.now().toString(36);
    63|    63|    63|    63|  }
