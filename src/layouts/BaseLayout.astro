<!-- Maintenance banner -->
<!-- To disable: set MAINTENANCE_ENABLED = false in BaseLayout.astro frontmatter -->
<!-- To force re-show after a dismiss: bump MAINTENANCE_VERSION -->
{MAINTENANCE_ENABLED && (
<div id="maintenance-banner" style="background-color: #fef3c7; border-bottom: 1px solid #fcd34d; color: #92400e; position: relative; z-index: 9999;">
