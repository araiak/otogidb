<!-- Dev-only features: hide on production, show on dev environments -->
<script is:inline>
(function() {
var host = location.hostname;
var search = location.search;
var isDev = (



search.includes('dev=true')
);
var style = document.createElement('style');
var rules = [];
if (!isDev) {
rules.push('[data-dev-only]{display:none!important}');
}
// Bug notices: hidden unless user opted in via "Show Bugs" checkbox
var showBugs = localStorage.getItem('otogidb-show-bugs') === 'true';
if (!showBugs) {
rules.push('[data-bug-notice]{display:none!important}');
}
if (rules.length > 0) {
style.textContent = rules.join('');
document.head.appendChild(style);
}
})();
</script>

<!-- Data version for cache busting -->
