---
import '../styles/global.css';
import { themeInitScript } from '../lib/theme';
import { localeInitScript, extractLocaleFromPath } from '../lib/i18n';
import DebugPanel from '../components/DebugPanel';
import SEO from '../components/SEO.astro';
import LocaleSwitcher from '../components/LocaleSwitcher';

// Favicon using Cloudinary transformation of card image (Sola - card 100014)
const CLOUDINARY_BASE = 'https://res.cloudinary.com/dn3j8sqcc/image/upload';
const FAVICON_CARD = 'otogi/cards_hd/100014_hd';
// Transformations: c_thumb with g_face detects and crops to face
const favicon32 = `${CLOUDINARY_BASE}/c_thumb,g_face,w_32,h_32,z_1.0/f_png/${FAVICON_CARD}.png`;
const favicon16 = `${CLOUDINARY_BASE}/c_thumb,g_face,w_16,h_16,z_1.0/f_png/${FAVICON_CARD}.png`;
const appleIcon = `${CLOUDINARY_BASE}/c_thumb,g_face,w_180,h_180,z_1.0/f_png/${FAVICON_CARD}.png`;

// Read data version and hashed paths at build time for cache busting
import cardsData from '../data/cards.json';
import fs from 'node:fs';
import path from 'node:path';

// Load data manifest with hashed file paths (generated by sync_website.py)
interface DataManifestFile {
cards_index: string;
cards_index_base: string;
cards_skeleton?: string;
}
// Tier list disabled - interface kept for future use
// interface DataManifestTiers {
//   path: string;
//   base: string;
// }
interface DataManifest {
generated_at: string;
files: Record<string, DataManifestFile>;
}

null = null;
try {
const manifestPath = path.resolve('./src/data/data_manifest.json');
if (fs.existsSync(manifestPath)) {
dataManifest = JSON.parse(fs.readFileSync(manifestPath, 'utf-8'));
}
} catch (e) {
console.warn('Could not load data_manifest.json:', e);
}

// Calculate hash of the full cards.json file for reliable cache busting
function getFileHash(filePath: string): string {
try {
const content = fs.readFileSync(filePath, 'utf-8');
let hash = 0;
// Use a larger sample of the file for speed while still being reliable
const sample = content.slice(0, 50000) + content.slice(-50000);
for (let i = 0; i < sample.length; i++) {
const char = sample.charCodeAt(i);
hash = ((hash << 5) - hash) + char;
hash = hash & hash;
}
return Math.abs(hash).toString(36);
} catch {
return Date.now().toString(36);
}
}

const cardsJsonPath = path.resolve('./src/data/cards.json');
const contentHash = getFileHash(cardsJsonPath);
'unknown'}-${contentHash}`;

// Build data paths object for client-side use
const dataPaths = {
{},
};

// Detect current locale from URL path
const currentPath = Astro.url.pathname;
const currentLocale = extractLocaleFromPath(currentPath);

interface Props {
title: string;
description?: string;
image?: string;
'article';
lang?: string;
/** Set to true for pages with localized URL versions (e.g., card detail pages) */
hasLocalizedUrls?: boolean;
/** Set to true on card table pages to preload icon files in <head> */
preloadIcons?: boolean;
article?: {
publishedTime?: string;
modifiedTime?: string;
author?: string;
tags?: string[];
};
}

const {
title,
description = 'Otogi Spirit Agents Card Database - Complete card stats, skills, and abilities',
image,
type = 'website',
lang = currentLocale,
hasLocalizedUrls = false,
preloadIcons = false,
article,
} = Astro.props;

// Build locale-aware navigation paths - all locales use /{locale}/ prefix
const localePrefix = `/${currentLocale}`;
const navLinks = {
home: localePrefix,
calendar: `${localePrefix}/calendar`,
updates: `${localePrefix}/updates`,
blog: `${localePrefix}/blog`,
tools: `${localePrefix}/tools`,
};

// ─── Maintenance banner ─────────────────────────────────────────────────────
// Set MAINTENANCE_ENABLED = false to hide without deleting the config/messages.
// Bump MAINTENANCE_VERSION (e.g. change the date/slug) to force the banner to
// re-appear for users who previously dismissed it.
const MAINTENANCE_ENABLED = true;
const MAINTENANCE_VERSION = "2026-05-06-spirit-theme-v2";
// Server-side messages using fixed GMT+8 times; client script refines to local tz
const maintenanceMessages: Record<string, string> = {
en:      'New "Spirit" theme is now available! Click the ✦ theme button in the header to switch themes.',
ja:      '新テーマ「Spirit」が利用可能になりました！ヘッダーのテーマボタン（✦）をクリックして切り替えてください。',
ko:      '새로운 "Spirit" 테마를 사용할 수 있습니다! 헤더의 테마 버튼(✦)을 눌러서 전환하세요.',
'zh-cn': '全新"Spirit"主题已上线！点击页头✦主题按钮即可切换。',
'zh-tw': '全新「Spirit」主題已上線！點擊頁頭✦主題按鈕即可切換。',
es:      '¡Nuevo tema "Spirit" disponible! Haz clic en el botón de tema ✦ de la cabecera para cambiar.',
};
const maintenanceMsg = maintenanceMessages[currentLocale] ?? maintenanceMessages['en'];
