<button id="maintenance-close" aria-label="Dismiss" title="Dismiss" style="margin-left:auto;background:none;border:none;cursor:pointer;padding:2px 6px;font-size:1.2rem;line-height:1;color:#92400e;flex-shrink:0;opacity:0.7;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">×</button>
</div>
</div>
)}
<script is:inline define:vars={{ maintenanceVersion: MAINTENANCE_VERSION, currentLocale: currentLocale }}>
(function() {
var STORAGE_KEY = 'otogidb-maintenance-dismissed';

// Hide immediately if user already dismissed this version (no flash)
try {
if (localStorage.getItem(STORAGE_KEY) === maintenanceVersion) {
var b = document.getElementById('maintenance-banner');
if (b) b.style.display = 'none';
return;
}
} catch(e) {}

// Auto-hide after ~2 weeks: May 20, 2026 00:00 GMT+8 = 1747699200000 UTC
var MAINTENANCE_END = 1747699200000;
if (Date.now() >= MAINTENANCE_END) {
var b = document.getElementById('maintenance-banner');
if (b) b.style.display = 'none';
return;
}
// Schedule auto-hide at end time
var remaining = MAINTENANCE_END - Date.now();
if (remaining > 0) {
setTimeout(function() {
var b = document.getElementById('maintenance-banner');
if (b) b.style.display = 'none';
}, remaining);
}

// Close button — saves current version so banner stays hidden until version changes
var closeBtn = document.getElementById('maintenance-close');
if (closeBtn) {
closeBtn.addEventListener('click', function() {
try { localStorage.setItem(STORAGE_KEY, maintenanceVersion); } catch(e) {}
var banner = document.getElementById('maintenance-banner');
if (banner) banner.style.display = 'none';
});
}
})();
</script>
